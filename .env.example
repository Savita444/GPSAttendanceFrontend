# Copy this file to `.env` (or `.env.local`) and restart `npm run dev`.

# Set to "true" to bypass the backend and serve all /api/* calls from
# the in-memory fixtures in src/mocks/data.js. Useful for UI work
# before the backend is ready.
VITE_USE_MOCKS=false

# Backend base URL (Vite proxy target). Use http://localhost:4000 for local.
# When deployed, set the proxy in vite.config.js OR ship a built app behind
# a reverse proxy that handles /api → backend.

# Pagination
VITE_DEFAULT_PAGE_SIZE=25
VITE_PAGE_SIZE_OPTIONS=10,25,50,100
VITE_ATTENDANCE_PAGE_SIZE=50

# Search debounce (ms)
VITE_SEARCH_DEBOUNCE_MS=300

# Branding
VITE_APP_NAME=Attendance MVP
VITE_BRAND_PRIMARY=#1A5DA0
